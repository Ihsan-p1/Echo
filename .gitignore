*.pt
*.onnx
*.onnx.json

# Audio and Image assets
*.wav
*.mp3
*.jpg
*.jpeg
*.png

# Project specific ignores
robot-assistant/voices/
robot-assistant/data/
robot-assistant/models/
runs/

# System-generated logs
robot-assistant/logs/

# User specifically requested Docs folder to be ignored
Docs/
