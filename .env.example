# Echo Robot Assistant - Environment Variables Template

# Roboflow API Key (for Hand Gesture / Object Detection datasets)
ROBOFLOW_API_KEY=your_roboflow_key_here

# Hugging Face Token (for Llama 3.2 3B Fine-Tuning/Model Download)
HF_TOKEN=your_huggingface_token_here

# Optional: Add other config here
# ROBOT_PORT=5000
# DEBUG_MODE=True
